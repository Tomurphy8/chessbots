# Tournament Orchestrator Configuration
# Copy this file to .env and fill in the values

# Monad Blockchain
MONAD_RPC=https://testnet-rpc.monad.xyz/
MONAD_CONTRACT=0x6b375B2306CD1C39de6BDA4f0bCfF49b44a5e35C
MONAD_USDC=0x34FAAfaf58750bc259d89Dd232FadAE5C1a4E7aa
CHESS_TOKEN=0x66c3770E0732C94A7a9df044c79E0859cAc5eB53
CHESS_STAKING=0xb87fCb0D46Be37550DEDF3e3f2db23f6d29E2749

# Deployer private key (for submitting results and distributing prizes)
# WARNING: Never commit your real private key!
PRIVATE_KEY=

# Chess engine internal URL
CHESS_ENGINE_URL=http://localhost:3001

# Service API key for authenticating with chess engine (must match chess-engine SERVICE_API_KEY)
SERVICE_API_KEY=
