# Tournament Orchestrator Configuration
# Copy this file to .env and fill in the values

# Monad Blockchain — Mainnet (chain ID 143)
MONAD_RPC=https://rpc.monad.xyz
MONAD_CONTRACT=0x0e2663b0DCD9b7408d51C6972f679B81a5A7477e
MONAD_USDC=0x754704Bc059F8C67012fEd69BC8A327a5aafb603
CHESS_TOKEN=0xC138bA72CE0234448FCCab4B2208a1681c5BA1fa
CHESS_STAKING=0xf242D07Ba9Aed9997c893B515678bc468D86E32C

# Deployer private key (for submitting results and distributing prizes)
# WARNING: Never commit your real private key!
PRIVATE_KEY=

# USDC amount to auto-fund each free tournament (0 = no funding)
FREE_TOURNAMENT_PRIZE_USDC=100

# Chess engine internal URL
CHESS_ENGINE_URL=http://localhost:3001

# Service API key for authenticating with chess engine (must match chess-engine SERVICE_API_KEY)
SERVICE_API_KEY=

# Agent gateway URL — REQUIRED for agents to receive game:started notifications
# Without this, agents won't know about games and will timeout without making moves
GATEWAY_URL=https://agent-gateway-production-590d.up.railway.app
