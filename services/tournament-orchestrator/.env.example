# Tournament Orchestrator Configuration
# Copy this file to .env and fill in the values

# Monad Blockchain — Mainnet (chain ID 143)
MONAD_RPC=https://rpc.monad.xyz
MONAD_CONTRACT=0x34FAAfaf58750bc259d89Dd232FadAE5C1a4E7aa
MONAD_USDC=0x754704Bc059F8C67012fEd69BC8A327a5aafb603
CHESS_TOKEN=0x6b375B2306CD1C39de6BDA4f0bCfF49b44a5e35C
CHESS_STAKING=0x66c3770E0732C94A7a9df044c79E0859cAc5eB53

# Deployer private key (for submitting results and distributing prizes)
# WARNING: Never commit your real private key!
PRIVATE_KEY=

# Chess engine internal URL
CHESS_ENGINE_URL=http://localhost:3001

# Service API key for authenticating with chess engine (must match chess-engine SERVICE_API_KEY)
SERVICE_API_KEY=
