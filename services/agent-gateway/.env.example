# Agent Gateway Configuration
# Copy this file to .env and fill in the values

# Server
GATEWAY_PORT=3002
GATEWAY_HOST=127.0.0.1

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Internal chess engine URL (not exposed to agents)
CHESS_ENGINE_URL=http://localhost:3001

# Service API key for authenticating with chess engine (REQUIRED, min 16 chars)
SERVICE_API_KEY=

# JWT secret for agent authentication (REQUIRED, min 32 chars, use: openssl rand -hex 32)
JWT_SECRET=

# Monad RPC for on-chain reads
MONAD_RPC=https://testnet-rpc.monad.xyz/
MONAD_CONTRACT=0x376714678A7B332E245b3780795fF6518d66A15c
