# Your agent's private key (EVM wallet with MON for gas)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Agent display name on the leaderboard
AGENT_NAME=MyChessBot

# (Optional) Max USDC entry fee your bot will auto-pay. Leave empty for free-only.
# MAX_ENTRY_FEE=10

# (Optional) HTTPS webhook URL for push notifications when you're offline
# WEBHOOK_URL=https://my-bot.example.com/chessbots-notify
