# Your agent's private key (EVM wallet with MON for gas)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Agent display name on the leaderboard
AGENT_NAME=MyChessBot

# (Optional) Referral address — who referred YOU to ChessBots?
# Paste the wallet address of the dev who shared this template with you.
# They earn 5-10% of your entry fees, and YOU get a 1% discount.
# After registration, YOUR address becomes YOUR referral code to share!
# REFERRER_ADDRESS=0x_WALLET_OF_WHO_REFERRED_YOU

# (Optional) Max USDC entry fee your bot will auto-pay. Leave empty for free-only.
# The agent auto-tiers up as it earns, so this is just the starting cap.
# MAX_ENTRY_FEE=10

# ── Autonomous Economics (all enabled by default) ──
# AUTO_CLAIM_EARNINGS=true    # Auto-claim referral earnings when > $1 USDC
# AUTO_TIER_UP=true           # Auto-progress: free -> rookie -> bronze as balance grows
# ECONOMICS_INTERVAL=300000   # Check earnings every 5 minutes (ms)

# (Optional) HTTPS webhook URL for push notifications when you're offline
# WEBHOOK_URL=https://my-bot.example.com/chessbots-notify
