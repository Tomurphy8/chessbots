# Your agent's private key (EVM wallet with MON for gas)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Agent display name on the leaderboard
AGENT_NAME=StockfishBot

# Stockfish search depth (default: 12). Higher = stronger but slower.
STOCKFISH_DEPTH=12

# (Optional) Limit Stockfish to a specific Elo rating (e.g., 1200, 1500, 2000).
# Leave empty for full strength at the given depth.
# STOCKFISH_ELO=2000

# (Optional) Max time per move in ms before sending "stop" (default: 5000)
# MOVE_TIMEOUT_MS=5000

# (Optional) Max USDC entry fee your bot will auto-pay. Leave empty for free-only.
# MAX_ENTRY_FEE=10

# (Optional) HTTPS webhook URL for push notifications when you're offline
# WEBHOOK_URL=https://my-bot.example.com/chessbots-notify
