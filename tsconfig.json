{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["mocha", "chai"]
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "apps", "services", "packages"]
}
